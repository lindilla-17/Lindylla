# .env.example — Plantilla de variables de entorno
#
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo ".env" NUNCA se sube a GitHub.
# Este archivo (.env.example) SÍ se sube — muestra qué variables se necesitan
# pero sin los valores reales.

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_base_datos
# O si usas Supabase:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=tu_clave_anonima
# SUPABASE_SERVICE_ROLE_KEY=tu_clave_de_servicio

# ── Autenticación ─────────────────────────────────────────────────────────────
# SECRET_KEY=clave_secreta_para_firmar_tokens
# JWT_EXPIRY=86400

# ── APIs externas ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_...

# ── Configuración del entorno ─────────────────────────────────────────────────
NODE_ENV=development
# o FLASK_ENV=development, etc.

# ── Añade aquí las variables específicas de tu proyecto ──────────────────────
