// Modelo de datos de Lindilla S.L. — ERP/CRM
// Base de datos local en un único archivo (SQLite). Fácil de copiar/respaldar.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- CRM: Empresas cliente, con jerarquía matriz -> delegación por país ---
model Empresa {
  id           String   @id @default(cuid())
  nombre       String
  tipo         String   @default("MATRIZ") // MATRIZ | DELEGACION
  pais         String?
  sector       String? // Oftalmología, Cirugía, Clínica...
  cif          String?
  email        String?
  telefono     String?
  direccion    String?
  notas        String?
  carpeta      String? // nombre de su carpeta en "trabajos empresas"
  parentId     String?
  parent       Empresa? @relation("Jerarquia", fields: [parentId], references: [id])
  hijos        Empresa[] @relation("Jerarquia")
  presupuestos Presupuesto[]
  facturas     Factura[]
  createdAt    DateTime @default(now())
}

// --- Catálogo de productos (flexible: gorros + cualquier otro) ---
model Producto {
  id            String   @id @default(cuid())
  nombre        String
  categoria     String   @default("GORRO") // GORRO | OTRO
  descripcion   String?
  precioBase    Float    @default(0)
  unidad        String   @default("ud")
  consumoTelaCm Float? // cm de tela por unidad (para calcular coste de gorros)
  activo        Boolean  @default(true)
  lineas        LineaPresupuesto[]
  createdAt     DateTime @default(now())
}

// --- Presupuestos: doble vía (pedido de gorros vs congreso) ---
model Presupuesto {
  id        String   @id @default(cuid())
  numero    String   @unique
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  tipo      String   @default("GORROS") // GORROS | CONGRESO
  fecha     DateTime @default(now())
  estado    String   @default("BORRADOR") // BORRADOR | ENVIADO | ACEPTADO | RECHAZADO
  notas     String?
  archivo   String? // nombre del PDF/Excel del presupuesto
  carpeta   String? // carpeta del pedido en "trabajos empresas"
  lineas    LineaPresupuesto[]
  factura   Factura? // si existe -> el pedido está completado
  createdAt DateTime @default(now())
}

model LineaPresupuesto {
  id             String  @id @default(cuid())
  presupuestoId  String
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  productoId     String?
  producto       Producto? @relation(fields: [productoId], references: [id])
  concepto       String
  categoria      String  @default("PRODUCTO") // PRODUCTO | TRANSPORTE | DIETAS | STAND | PERSONALIZACION | OTRO
  cantidad       Float   @default(1)
  precioUnitario Float   @default(0)
}

// --- Facturas: nacen de un presupuesto. Sin factura = pedido no completado ---
model Factura {
  id               String   @id @default(cuid())
  numero           String   @unique
  empresaId        String
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  presupuestoId    String?  @unique
  presupuesto      Presupuesto? @relation(fields: [presupuestoId], references: [id])
  fecha            DateTime @default(now())
  fechaVencimiento DateTime?
  estado           String   @default("PENDIENTE") // PAGADA | PENDIENTE
  fechaPago        DateTime?
  neto             Float    @default(0) // base imponible (sin IVA)
  iva              Float    @default(0) // IVA repercutido (0 en ventas intracomunitarias/exportación)
  total            Float    @default(0) // neto + iva
  concepto         String?
  lineasJson       String? // líneas de la factura en JSON (para las creadas desde la web)
  archivo          String? // nombre del PDF de la factura (para localizarlo en las carpetas)
  notas            String?
  createdAt        DateTime @default(now())
}

// ============================================================
// CENTROVEO — actividad sanitaria de Lindilla S.L. (óptica/optometría)
// Gestión TOTALMENTE independiente de la actividad de gorros:
// sus datos viven en estas tablas y no se mezclan con las de arriba.
// ============================================================

// Facturas emitidas por Centroveo. Dos tipos de facturación:
//  - LENTES: venta de lentes de contacto, IVA 10%
//  - PROFESIONAL: servicios de optometría (Hospital Vithas Xanit),
//    exentos de IVA por ser servicios sanitarios (art. 20 LIVA)
model CentroveoFactura {
  id        String    @id @default(cuid())
  numero    String    @unique
  tipo      String    @default("LENTES") // LENTES | PROFESIONAL
  cliente   String
  concepto  String?
  fecha     DateTime  @default(now())
  estado    String    @default("PENDIENTE") // PAGADA | PENDIENTE
  fechaPago DateTime?
  neto      Float     @default(0)
  iva       Float     @default(0) // 10% en lentes; 0 en servicios sanitarios exentos
  total     Float     @default(0)
  archivo   String?
  notas     String?
  trabajos  CentroveoTrabajo[] // partes de agenda que se facturaron aquí
  createdAt DateTime  @default(now())
}

// Actividades de la agenda, definidas por la usuaria: cada una con su
// nombre, color, si es facturable y su precio. Se pueden añadir las que
// quiera (facturables o no, p. ej. una nota interna que no se cobra).
model CentroveoActividad {
  id         String             @id @default(cuid())
  nombre     String
  color      String             @default("#4e8f84") // color elegido por la usuaria
  facturable Boolean            @default(true) // si suma a la factura profesional del mes
  precio     Float              @default(0) // precio por unidad (solo si facturable)
  orden      Int                @default(0)
  activa     Boolean            @default(true) // desactivada = no se ofrece para nuevos apuntes
  trabajos   CentroveoTrabajo[]
  createdAt  DateTime           @default(now())
}

// Agenda de trabajo profesional: cada apunte es el trabajo de un día
// (nº de una actividad). Al facturar el mes se enlaza a una factura.
model CentroveoTrabajo {
  id          String             @id @default(cuid())
  fecha       DateTime
  actividadId String
  actividad   CentroveoActividad @relation(fields: [actividadId], references: [id])
  cantidad    Int                @default(1)
  notas       String?
  facturaId   String? // si ya se facturó, apunta a la CentroveoFactura del mes
  factura     CentroveoFactura?  @relation(fields: [facturaId], references: [id])
  createdAt   DateTime           @default(now())
}

// Facturas de proveedores de Centroveo (compras de lentes, material óptico...)
model CentroveoGasto {
  id        String    @id @default(cuid())
  proveedor String
  concepto  String
  fecha     DateTime  @default(now())
  neto      Float     @default(0)
  iva       Float     @default(0)
  importe   Float     @default(0)
  estado    String    @default("PENDIENTE") // PAGADO | PENDIENTE
  fechaPago DateTime?
  archivo   String?
  notas     String?
  createdAt DateTime  @default(now())
}

// --- Gastos: dinero a pagar (compras, proveedores, logística de congresos...) ---
model Gasto {
  id               String   @id @default(cuid())
  concepto         String
  categoria        String   @default("GENERAL") // MATERIAL | PERSONAL | LOGISTICA | CONGRESO | GENERAL
  proveedor        String?
  fecha            DateTime @default(now())
  fechaVencimiento DateTime?
  neto             Float    @default(0) // base imponible
  iva              Float    @default(0) // IVA soportado (deducible)
  importe          Float    @default(0) // total pagado
  estado           String   @default("PENDIENTE") // PAGADO | PENDIENTE
  fechaPago        DateTime?
  archivo          String? // justificante en la carpeta de cuentas
  createdAt        DateTime @default(now())
}
